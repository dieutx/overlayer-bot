# Overlayer Bot Configuration

# The global auth token (JWT) used to fetch tasks from the Overlayer API.
GLOBAL_AUTH_TOKEN=

# The master address associated with the global auth token.
GLOBAL_AUTH_ADDRESS=

# Optional proxy used only for fetching daily tasks from Overlayer API.
# If empty, bot falls back to the first wallet proxy.
GLOBAL_PROXY=

# Optional: Custom Sepolia RPC URL (leave blank to use built-in fallbacks)
RPC=

# Wallet private keys. Use comma-separated or newline-separated values.
PRIVATE_KEYS=

# Optional proxies. Leave empty to run directly through local network.
# Supported formats include host:port, host:port:user:pass, or a full proxy URL.
PROXIES=

# Number of wallets to process in parallel.
WALLET_CONCURRENCY=4

# Set to 1 to run only extra dummy transaction top-ups.
DUMMY_TX_TOPUP_ONLY=0
