# Overlayer Bot Configuration

# The global auth token (JWT) used to fetch tasks from the Overlayer API
GLOBAL_AUTH_TOKEN=your_global_auth_token_here

# The master address associated with the global auth token
GLOBAL_AUTH_ADDRESS=0xyour_master_address_here

# Optional: Custom Sepolia RPC URL (leave blank to use built-in fallbacks)
RPC=

# Wallet private keys. Use comma-separated values.
# Example: PRIVATE_KEYS=0xabc...,0xdef...
PRIVATE_KEYS=

# Optional proxies. Leave empty to run directly through local network.
# Supported formats: ip:port:user:pass, ip:port, http://user:pass@ip:port
# Example: PROXIES=1.2.3.4:8000:user:pass,5.6.7.8:9000
PROXIES=

# Number of wallets to process in parallel.
WALLET_CONCURRENCY=1
