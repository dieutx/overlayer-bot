{
  "name": "overlayer-sepolia-task-bot",
  "version": "1.0.0",
  "description": "Multi-wallet Overlayer Sepolia daily task automation with proxy rotation and local progress tracking.",
  "main": "dist/index.js",
  "scripts": {
    "start": "dotenvx run --ignore=MISSING_ENV_FILE -f .env -f .env.example -- ts-node src/index.ts",
    "start:plain": "ts-node src/index.ts",
    "test": "node --test -r ts-node/register tests/*.test.js",
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "secrets:encrypt": "dotenvx encrypt",
    "secrets:decrypt": "dotenvx decrypt"
  },
  "keywords": [
    "overlayer",
    "sepolia",
    "automation",
    "ethers",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@types/node": "^25.9.1",
    "ethers": "^6.16.0",
    "https-proxy-agent": "^9.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "undici": "^8.3.0"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.69.1"
  }
}
